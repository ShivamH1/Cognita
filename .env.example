# ─── COGNITA — BACKEND ENVIRONMENT (save as apps/api/.env) ─────────────────────
PORT=8000

# Postgres (Prisma)
DATABASE_URL=postgresql://cognita:cognita@localhost:5432/cognita?schema=public

# Redis (BullMQ + cache)
REDIS_URL=redis://localhost:6379

# Qdrant (vector store)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Local embedding model (Transformers.js, downloaded on first run)
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

# ─── LLM GATEWAY ───────────────────────────────────────────────────────────────
# Failover order: tries each provider in turn on 429/error.
LLM_PROVIDER_ORDER=openrouter,mistral,groq

# OpenRouter — https://openrouter.ai/  (OpenAI-compatible)
OPENROUTER_API_KEY=sk-or-your-key
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Mistral — https://console.mistral.ai/  (OpenAI-compatible)
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
MISTRAL_BASE_URL=https://api.mistral.ai/v1

# Groq — https://console.groq.com/  (OpenAI-compatible)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ─── AUTH ──────────────────────────────────────────────────────────────────────
# Shared secret between the Next.js Auth.js app and the Express API (JWT verify).
AUTH_SECRET=change-me-to-a-long-random-string

# CORS Allowed Origin
FRONTEND_URL=http://localhost:3000

# ─── FRONTEND ENVIRONMENT (save as apps/web/.env.local) ────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
# Auth.js (must match the API's AUTH_SECRET)
AUTH_SECRET=change-me-to-a-long-random-string
# Prisma needs the same DB url in the web app for the Auth.js adapter
DATABASE_URL=postgresql://cognita:cognita@localhost:5432/cognita?schema=public
